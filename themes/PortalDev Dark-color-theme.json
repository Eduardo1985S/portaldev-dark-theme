  "tokenColors": [
    // ── Comentários ─────────────────────────────────────────
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7EC87E",
        "fontStyle": "italic"
      }
    },

    // ── Keywords ────────────────────────────────────────────
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#DA6FD5"
      }
    },
    {
      "name": "Keyword Operator Assignment",
      "scope": [
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#E8E8E8"
      }
    },

    // ── Operadores ──────────────────────────────────────────
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.logical",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest"
      ],
      "settings": {
        "foreground": "#E8E8E8"
      }
    },

    // ── Variáveis ───────────────────────────────────────────
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object",
        "variable.other.constant",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },
    {
      "name": "Variable Language (this, self)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#6CB6FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },

    // ── Funções ─────────────────────────────────────────────
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#FFE066"
      }
    },
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },

    // ── Strings ─────────────────────────────────────────────
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple"
      ],
      "settings": {
        "foreground": "#F0A875"
      }
    },
    {
      "name": "String Escape Characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#E8C975"
      }
    },
    {
      "name": "Template String Interpolation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "string.template meta.template.expression"
      ],
      "settings": {
        "foreground": "#DA6FD5"
      }
    },

    // ── Números ─────────────────────────────────────────────
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#C8E6A1"
      }
    },

    // ── Constantes Booleanas / Null / Undefined ─────────────
    {
      "name": "Boolean / Null / Undefined",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#6CB6FF"
      }
    },

    // ── Tipos / Classes ─────────────────────────────────────
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
